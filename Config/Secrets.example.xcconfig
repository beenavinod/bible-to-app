// Copy this file to Secrets.xcconfig in the same folder and fill in real values.
// Secrets.xcconfig is listed in .gitignore — do not commit it.
//
// xcconfig treats // as a comment, so use the $() empty-variable trick to escape it:
//   https:$()/$()/your-project-id.supabase.co
// Xcode evaluates $() to an empty string, producing https://your-project-id.supabase.co at build time.

SUPABASE_URL = https:$()/$()/your-project-id.supabase.co
SUPABASE_ANON_KEY = your-anon-key-here
