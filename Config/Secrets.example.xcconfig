// Copy this file to Secrets.xcconfig in the same folder and fill in real values.
// Secrets.xcconfig is listed in .gitignore — do not commit it.
//
// Use double quotes around SUPABASE_URL so https:// is not treated as an xcconfig comment.

SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_ANON_KEY = "your-anon-key-here"
